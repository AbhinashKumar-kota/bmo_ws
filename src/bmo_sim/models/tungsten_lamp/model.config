<?xml version="1.0"?>
<model>
  <name>tungsten_lamp</name>
  <version>1.0</version>
  <sdf version="1.8">model.sdf</sdf>
  <description>
    Visual marker representing a tungsten filament lamp (signal source).
    Static model — no physics. Just a small cylinder with an orange point light
    so you can see the source position in Gazebo.
  </description>
</model>
